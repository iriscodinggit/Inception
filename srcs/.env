DOMAIN_NAME=irlozano.42.fr

# MYSQL / MARIADB SETUP -> CHANGE IT!!!:
MYSQL_USER=XXXXXXXXXXXX
MYSQL_ROOT_PASSWORD=supersecretrootpassword
#upon starting, mariadb should create a database automatically, which is called wordpress
MYSQL_DATABASE=wordpress
MYSQL_PASSWORD=supersecretpassword

# WordPress setup
#tells wordpress how to reach the database (via mariadb service port 3306)
WORDPRESS_DB_HOST=mariadb:3306
#tells wordpress what database to use (the one that mariadb created ealier)
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=XXXXXXXXXXXX
WORDPRESS_DB_PASSWORD=supersecretpassword